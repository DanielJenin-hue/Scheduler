{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "breakroom_layout_scorecard.v1",
  "title": "Breakroom Layout Scorecard v1",
  "description": "Structured visual-quality grade for a rendered breakroom printout. Produced by a vision-LLM seam and consumed by a threshold pass/fail gate.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "image_path", "paper_size", "scores", "overall", "pass"],
  "properties": {
    "schema": {
      "const": "breakroom_layout_scorecard.v1"
    },
    "rendered_at": {
      "type": "string",
      "description": "ISO-8601 timestamp the snapshot was scored."
    },
    "image_path": {
      "type": "string",
      "description": "Path to the PNG snapshot that was graded."
    },
    "paper_size": {
      "type": "string",
      "enum": ["legal", "ledger", "letter"]
    },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readability",
        "text_clipping",
        "contrast",
        "layout_density",
        "gap_legibility"
      ],
      "properties": {
        "readability": {"type": "integer", "minimum": 0, "maximum": 100},
        "text_clipping": {"type": "integer", "minimum": 0, "maximum": 100},
        "contrast": {"type": "integer", "minimum": 0, "maximum": 100},
        "layout_density": {"type": "integer", "minimum": 0, "maximum": 100},
        "gap_legibility": {"type": "integer", "minimum": 0, "maximum": 100}
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "category", "note"],
        "properties": {
          "severity": {"type": "string", "enum": ["low", "med", "high"]},
          "category": {
            "type": "string",
            "enum": [
              "readability",
              "text_clipping",
              "contrast",
              "layout_density",
              "gap_legibility",
              "pagination",
              "other"
            ]
          },
          "where": {
            "type": "string",
            "description": "Locator, e.g. 'row 12 / 06-14' or 'header'."
          },
          "note": {"type": "string"}
        }
      }
    },
    "overall": {"type": "integer", "minimum": 0, "maximum": 100},
    "pass": {"type": "boolean"}
  }
}
